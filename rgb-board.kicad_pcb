	(gr_text "D101-D110: BAT46W (SOD-123)\nD201: BZT52C12 (12V Zener, SOD-123)\n\nAll transistors (Q101, Q102, ...): BC850\n\nC101,102,103: 47uF/25V E-cap\nC104,105,120,122: 10uF/25V E-cap\nC115,207: 100 uF/16V E-Cap\nC114,116,117,118,119,206: 100 nF/25V MLCC\nC203: 1 uF/50V E-Cap\nC121: 1 uF/25V MLCC\nC201,202,205: 180 pF MLCC\nC204: 39 pF MLCC\nMLCC caps are 0805\n\nR101,115,129,143,152: 75 Ohm\nR104,114,118,128,132,142,146,155: 100 Ohm\nR113,127,141: 390 Ohm\nR105,119,133,203: 56 kOhm\nR106,120,134,147,148,156,157: 33 kOhm\nR107,121,135: 1.5 kOhm\nR202: 1 kOhm\nR204: 68 kOhm\nR149,158,205: 2.7 kOhm\nR3: 20 kOhm\nR1,2: 470 Ohm\nAll resistors: 0805 1% tolerance\n\nF1: 1812L050PR 15V 0.5A Fuse\nK1: OMRON G6K-2PY-12DC Relay\n\nU1: NCP1117-12 (SOT-223)\n\nSW1: ALPS SPUJ190900\nSW2: ALPS SPUJ193700\n\nSCART: Ninigi right angled\n(or similar)"
		(at 157.1 94.05 0)
		(layer "F.SilkS")
		(uuid "00000000-0000-0000-0000-00005ff3f631")
		(effects
			(font
				(size 1.5 1.5)
				(thickness 0.3)
			)
			(justify left)
		)
	)
